PORT=3001
MONGODB_URI=mongodb://localhost:27017/tiertogether
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Google OAuth (required for auth features)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
JWT_SECRET=your-jwt-secret-change-in-production

# Google Custom Search (for image search feature)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Resend (for email verification)
RESEND_API_KEY=
RESEND_FROM_EMAIL=TierTogether <onboarding@resend.dev>

